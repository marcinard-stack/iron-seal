{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/view/:token", "destination": "/viewer.html" },
    { "source": "/deals/:status/:slug", "destination": "/viewer.html" },
    { "source": "/deals/:status", "destination": "/dashboard.html" },
    { "source": "/deals", "destination": "/dashboard.html" }
  ]
}
